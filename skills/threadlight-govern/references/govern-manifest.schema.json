{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "threadlight-govern-manifest/v2",
  "title": "threadlight govern manifest",
  "description": "Emitted by threadlight-govern (scripts/govern_check.py). Consumed by threadlight-production-ready pillars 2 (agent-governance) and 7 (responsible-ai).",
  "type": "object",
  "required": ["schema", "tool_version", "captured_at", "verdict", "capabilities"],
  "properties": {
    "schema": {"const": "threadlight-govern-manifest/v2"},
    "tool_version": {"type": "string"},
    "captured_at": {"type": "string", "format": "date-time"},
    "agt_profile": {"enum": ["auto", "v3_7", "v4_preview", "none"]},
    "freshness_window_days": {"type": "integer", "minimum": 0},
    "verdict": {"enum": ["governed", "partial", "ungoverned"]},
    "must_fix": {"type": "array", "items": {"type": "string"}},
    "should_fix": {"type": "array", "items": {"type": "string"}},
    "not_verified": {"type": "array", "items": {"type": "string"}},
    "capabilities": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": {
            "enum": ["pass", "must-fix", "should-fix", "not-verified", "not-applicable"]
          },
          "evidence": {"type": ["string", "null"]},
          "hint": {"type": ["string", "null"]}
        }
      },
      "propertyNames": {
        "enum": [
          "policy_artefact_present",
          "policy_schema_valid",
          "policy_versioned",
          "policy_default_deny",
          "sensitive_action_rules_present",
          "policy_tests_present",
          "ci_gate_present",
          "attestation_present",
          "attestation_fresh",
          "asi_reference_present"
        ]
      }
    }
  }
}
