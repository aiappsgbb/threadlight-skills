# Generated by threadlight-cicd v{{GENERATOR_VERSION}} on {{ISO_TIMESTAMP}}.
#
# Production deploy for a Threadlight pilot via GitHub OIDC federated credentials.
# NO long-lived secrets: client-id / tenant-id / subscription-id are public
# identifiers, not secrets. You may move them to repository variables
# (Settings > Secrets and variables > Actions > Variables) if you prefer; this
# template inlines them to stay self-contained.
#
# Onboarding path: {{ONBOARDING_PATH}} | posture: {{POSTURE}}
# Scope guard: this pipeline deploys ONLY use-case resources into
# {{TARGET_RESOURCE_GROUP}}. It must never deploy or modify the central Citadel
# hub. See docs/threadlight-cicd/central-platform-boundary.md.

name: azd-deploy-prod

on:
  workflow_dispatch: {}
  push:
    branches: [ main ]
    paths-ignore: [ '**.md', 'docs/**' ]

permissions:
  id-token: write
  contents: read

env:
  AZURE_CLIENT_ID: {{AZURE_CLIENT_ID}}
  AZURE_TENANT_ID: {{TENANT_ID}}
  AZURE_SUBSCRIPTION_ID: {{TARGET_SUBSCRIPTION_ID}}
  AZURE_ENV_NAME: {{ENV_NAME}}
  AZURE_LOCATION: {{TARGET_LOCATION}}

jobs:
  deploy:
    # 'environment: {{ENV_NAME}}' enables required-reviewer approval gates.
    runs-on: {{RUNNER_RUNS_ON}}
    environment: {{ENV_NAME}}
    steps:
      - uses: actions/checkout@v4

      - name: Install azd
        uses: Azure/setup-azd@v2

      - name: Azure login (OIDC federated credentials)
        uses: azure/login@v2
        with:
          client-id: {{AZURE_CLIENT_ID}}
          tenant-id: {{TENANT_ID}}
          subscription-id: {{TARGET_SUBSCRIPTION_ID}}

      - name: azd auth login (federated, no secret)
        run: >
          azd auth login
          --client-id "$AZURE_CLIENT_ID"
          --federated-credential-provider github
          --tenant-id "$AZURE_TENANT_ID"

      - name: Provision infrastructure
        run: azd provision --no-prompt

      - name: Deploy services
        run: azd deploy --no-prompt

      - name: Production-readiness re-assessment (non-blocking)
        continue-on-error: true
        run: echo "Re-run threadlight-production-ready assess against the deployed environment."
