# Generated by threadlight-cicd v{{GENERATOR_VERSION}} on {{ISO_TIMESTAMP}}.
#
# Production deploy for a Threadlight pilot via GitHub OIDC federated credentials.
# NO long-lived secrets: client-id / tenant-id / subscription-id are public
# identifiers, not secrets. You may move them to repository variables
# (Settings > Secrets and variables > Actions > Variables) if you prefer; this
# template inlines them to stay self-contained.
#
# Onboarding path: {{ONBOARDING_PATH}} | posture: {{POSTURE}}
# Scope guard: this pipeline deploys ONLY use-case resources into
# {{TARGET_RESOURCE_GROUP}}. It must never deploy or modify the central Citadel
# hub. See docs/threadlight-cicd/central-platform-boundary.md.

name: azd-deploy-prod

on:
  workflow_dispatch: {}
  push:
    branches: [ main ]
    paths-ignore: [ '**.md', 'docs/**' ]

permissions:
  id-token: write
  contents: read

env:
  AZURE_CLIENT_ID: {{AZURE_CLIENT_ID}}
  AZURE_TENANT_ID: {{TENANT_ID}}
  AZURE_SUBSCRIPTION_ID: {{TARGET_SUBSCRIPTION_ID}}
  AZURE_ENV_NAME: {{ENV_NAME}}
  AZURE_LOCATION: {{TARGET_LOCATION}}

jobs:
  deploy:
    # 'environment: {{ENV_NAME}}' enables required-reviewer approval gates.
    runs-on: {{RUNNER_RUNS_ON}}
    environment: {{ENV_NAME}}
    steps:
      - uses: actions/checkout@v4

      - name: Install azd
        uses: Azure/setup-azd@v2

      - name: Azure login (OIDC federated credentials)
        uses: azure/login@v2
        with:
          client-id: {{AZURE_CLIENT_ID}}
          tenant-id: {{TENANT_ID}}
          subscription-id: {{TARGET_SUBSCRIPTION_ID}}

      - name: Reuse az login session for azd (no second token exchange)
        run: azd config set auth.useAzCliAuth true

      - name: Seed azd environment (idempotent on a clean CI checkout)
        run: >
          azd env new "$AZURE_ENV_NAME"
          --subscription "$AZURE_SUBSCRIPTION_ID"
          --location "$AZURE_LOCATION"
          --no-prompt || true

      - name: Provision infrastructure
        run: azd provision --no-prompt

      - name: Deploy services
        run: azd deploy --no-prompt

      - name: Production-readiness re-assessment (non-blocking)
        continue-on-error: true
        run: echo "Re-run threadlight-production-ready assess against the deployed environment."

  # CAF "build agents across your organization": standardized evaluation +
  # dedicated AI red teaming, integrated into CI/CD. Both gates run the
  # threadlight Discover legs against the freshly deployed agent and enforce
  # their verdict. Gate mode: {{EVAL_GATE_MODE}} (soft = warn-only,
  # hard = block the pipeline on a non-pass verdict).
  eval-gate:
    needs: deploy
    runs-on: {{RUNNER_RUNS_ON}}
    environment: {{ENV_NAME}}
    env:
      AZURE_ENV_NAME: {{ENV_NAME}}
    steps:
      - uses: actions/checkout@v4

      - name: Azure login (OIDC federated credentials)
        uses: azure/login@v2
        with:
          client-id: {{AZURE_CLIENT_ID}}
          tenant-id: {{TENANT_ID}}
          subscription-id: {{TARGET_SUBSCRIPTION_ID}}

      - name: Run quality evals (threadlight-evals Discover leg)
        run: >
          echo "Run threadlight-evals against $AZURE_ENV_NAME to (re)produce
          specs/evals-manifest.json — offline batch (foundry-evals),
          online/continuous eval on live threads, and the A/B
          champion-challenger gate."

      - name: Enforce eval verdict (mode={{EVAL_GATE_MODE}})
        continue-on-error: {{EVAL_GATE_SOFT}}
        run: |
          python3 - <<'PY'
          import json, os, sys
          p = "specs/evals-manifest.json"
          if not os.path.exists(p):
              print(f"::warning::{p} missing — evals leg has not run.")
              sys.exit(1)
          verdict = json.load(open(p)).get("verdict", "not-verified")
          print(f"evals verdict: {verdict}")
          # no must-fix -> comprehensive|partial ship; offline-only|none block
          sys.exit(0 if verdict in ("comprehensive", "partial") else 1)
          PY

  red-team-gate:
    needs: deploy
    runs-on: {{RUNNER_RUNS_ON}}
    environment: {{ENV_NAME}}
    env:
      AZURE_ENV_NAME: {{ENV_NAME}}
    steps:
      - uses: actions/checkout@v4

      - name: Azure login (OIDC federated credentials)
        uses: azure/login@v2
        with:
          client-id: {{AZURE_CLIENT_ID}}
          tenant-id: {{TENANT_ID}}
          subscription-id: {{TARGET_SUBSCRIPTION_ID}}

      - name: Run adversarial scan (threadlight-redteam Discover leg)
        run: >
          echo "Run threadlight-redteam against $AZURE_ENV_NAME to produce
          docs/redteam-report.md + specs/redteam-manifest.json — AI Red Teaming
          Agent scan for jailbreak / prompt-injection / exfiltration /
          harmful-content."

      - name: Enforce red-team verdict (mode={{EVAL_GATE_MODE}})
        continue-on-error: {{EVAL_GATE_SOFT}}
        run: |
          python3 - <<'PY'
          import json, os, sys
          p = "specs/redteam-manifest.json"
          if not os.path.exists(p):
              print(f"::warning::{p} missing — red-team scan has not run.")
              sys.exit(1)
          verdict = json.load(open(p)).get("verdict", "not-verified")
          print(f"red-team verdict: {verdict}")
          # no must-fix -> hardened|partial ship; vulnerable blocks
          sys.exit(0 if verdict in ("hardened", "partial") else 1)
          PY

  # MCP supply-chain gate — verify the deployed repo's MCP servers/tools are
  # pinned, registry-resolvable, lock-tracked, and credential-clean before it
  # ships. Gate mode: {{MCP_GATE_MODE}} (soft = warn-only, hard = block on any
  # must-fix MCP finding). Reads the mcp-sbom.json the production-ready assessor
  # writes next to its manifest (tests/mcp-sbom.json).
  mcp-supply-chain-gate:
    needs: deploy
    runs-on: {{RUNNER_RUNS_ON}}
    environment: {{ENV_NAME}}
    env:
      AZURE_ENV_NAME: {{ENV_NAME}}
    steps:
      - uses: actions/checkout@v4

      - name: Azure login (OIDC federated credentials)
        uses: azure/login@v2
        with:
          client-id: {{AZURE_CLIENT_ID}}
          tenant-id: {{TENANT_ID}}
          subscription-id: {{TARGET_SUBSCRIPTION_ID}}

      - name: Produce MCP SBOM (threadlight-production-ready)
        run: >
          echo "Run threadlight-production-ready against the repo to (re)produce
          tests/mcp-sbom.json — MCP server/tool discovery, pin + registry
          verification, mcp-lock.json drift, and inline-credential scan."

      - name: Enforce MCP supply-chain verdict (mode={{MCP_GATE_MODE}})
        continue-on-error: {{MCP_GATE_SOFT}}
        run: |
          python3 - <<'PY'
          import json, os, sys
          p = "tests/mcp-sbom.json"
          if not os.path.exists(p):
              print(f"::warning::{p} missing — MCP SBOM has not been produced.")
              sys.exit(1)
          summary = json.load(open(p)).get("summary", {})
          must_fix = summary.get("must_fix", 0)
          print(f"MCP must-fix findings: {must_fix}")
          sys.exit(1 if must_fix else 0)
          PY
