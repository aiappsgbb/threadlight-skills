#!/usr/bin/env bash
# 02 — RBAC role assignment, scoped to the target resource group (least privilege).
# Generated by threadlight-cicd v{{GENERATOR_VERSION}}.
set -euo pipefail

# Ensure the target resource group exists (idempotent).
az group create \
  --name "{{TARGET_RESOURCE_GROUP}}" \
  --subscription "{{TARGET_SUBSCRIPTION_ID}}" \
  --location "{{TARGET_LOCATION}}"

PRINCIPAL_ID=$(az identity show \
  --name "{{UAMI_NAME}}" --resource-group "{{UAMI_RESOURCE_GROUP}}" \
  --query principalId -o tsv)

# 1) Deploy role for the use-case resources.
az role assignment create \
  --assignee-object-id "$PRINCIPAL_ID" \
  --assignee-principal-type ServicePrincipal \
  --role "{{RBAC_ROLE}}" \
  --scope "{{RBAC_SCOPE_ID}}"

# 2) RBAC admin (same RG scope) so keyless `azd provision` can assign the
#    app identity's data-plane roles. Without this, provision fails with
#    AuthorizationFailed on Microsoft.Authorization/roleAssignments/write.
az role assignment create \
  --assignee-object-id "$PRINCIPAL_ID" \
  --assignee-principal-type ServicePrincipal \
  --role "{{RBAC_RA_ADMIN_ROLE}}" \
  --scope "{{RBAC_SCOPE_ID}}"
