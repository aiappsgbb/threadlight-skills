#!/usr/bin/env bash
# 02 — RBAC role assignment, scoped to the target resource group (least privilege).
# Generated by threadlight-cicd v{{GENERATOR_VERSION}}.
set -euo pipefail

PRINCIPAL_ID=$(az identity show \
  --name "{{UAMI_NAME}}" --resource-group "{{UAMI_RESOURCE_GROUP}}" \
  --query principalId -o tsv)

az role assignment create \
  --assignee-object-id "$PRINCIPAL_ID" \
  --assignee-principal-type ServicePrincipal \
  --role "{{RBAC_ROLE}}" \
  --scope "{{RBAC_SCOPE_ID}}"
