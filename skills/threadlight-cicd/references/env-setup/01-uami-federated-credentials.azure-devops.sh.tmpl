#!/usr/bin/env bash
# 01 — UAMI + Azure DevOps WIF federated credential (run by the platform team).
# Generated by threadlight-cicd v{{GENERATOR_VERSION}}. No secrets are created.
set -euo pipefail

UAMI_NAME="{{UAMI_NAME}}"
RG="{{UAMI_RESOURCE_GROUP}}"
SUB="{{UAMI_SUBSCRIPTION_ID}}"
# Obtain ISSUER from the Azure DevOps WIF service connection page (manual mode).
ISSUER="${ADO_ISSUER:-<issuer-from-ado-service-connection>}"

az identity create --name "$UAMI_NAME" --resource-group "$RG" --subscription "$SUB"

az identity federated-credential create \
  --name "ado-{{ADO_ORG}}-{{ENV_NAME}}" \
  --identity-name "$UAMI_NAME" --resource-group "$RG" \
  --issuer "$ISSUER" \
  --subject "{{FED_SUBJECT_ADO}}" \
  --audiences "api://AzureADTokenExchange"

echo "UAMI client id (use as the identity behind {{ADO_SERVICE_CONNECTION}}):"
az identity show -n "$UAMI_NAME" -g "$RG" --query clientId -o tsv
