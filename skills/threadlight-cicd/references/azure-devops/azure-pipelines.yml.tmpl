# Generated by threadlight-cicd v{{GENERATOR_VERSION}} on {{ISO_TIMESTAMP}}.
#
# Production deploy for a Threadlight pilot via an Azure DevOps Workload Identity
# Federation (WIF) ARM service connection. NO secret / PAT: the service
# connection '{{ADO_SERVICE_CONNECTION}}' federates to a user-assigned managed
# identity (see docs/threadlight-cicd/env-setup/01-uami-federated-credentials.md).
#
# Onboarding path: {{ONBOARDING_PATH}} | posture: {{POSTURE}}
# Scope guard: deploys ONLY use-case resources into {{TARGET_RESOURCE_GROUP}};
# never the central Citadel hub. See docs/threadlight-cicd/central-platform-boundary.md.

trigger:
  branches:
    include: [ main ]

pool:
  {{ADO_POOL_SPEC}}

variables:
  - name: AZURE_ENV_NAME
    value: {{ENV_NAME}}
  - name: AZURE_LOCATION
    value: {{TARGET_LOCATION}}
  - name: AZURE_SUBSCRIPTION_ID
    value: {{TARGET_SUBSCRIPTION_ID}}

stages:
  - stage: deploy
    displayName: Deploy ({{ENV_NAME}})
    jobs:
      - deployment: azd_deploy
        # Bind an ADO Environment to enable approval checks for production.
        environment: {{ENV_NAME}}
        strategy:
          runOnce:
            deploy:
              steps:
                - checkout: self
                - task: AzureCLI@2
                  displayName: Install azd
                  inputs:
                    azureSubscription: {{ADO_SERVICE_CONNECTION}}
                    scriptType: bash
                    scriptLocation: inlineScript
                    inlineScript: |
                      set -euo pipefail
                      curl -fsSL https://aka.ms/install-azd.sh | bash
                - task: AzureCLI@2
                  displayName: Provision and deploy (azd)
                  inputs:
                    azureSubscription: {{ADO_SERVICE_CONNECTION}}
                    scriptType: bash
                    scriptLocation: inlineScript
                    inlineScript: |
                      set -euo pipefail
                      # AzureCLI@2 already established a federated az session via
                      # the WIF service connection; let azd reuse it.
                      azd config set auth.useAzCliAuth "true"
                      azd provision --no-prompt
                      azd deploy --no-prompt
