# Generated by threadlight-cicd v{{GENERATOR_VERSION}} on {{ISO_TIMESTAMP}}.
#
# Production deploy for a Threadlight pilot via an Azure DevOps Workload Identity
# Federation (WIF) ARM service connection. NO secret / PAT: the service
# connection '{{ADO_SERVICE_CONNECTION}}' federates to a user-assigned managed
# identity (see docs/threadlight-cicd/env-setup/01-uami-federated-credentials.md).
#
# Onboarding path: {{ONBOARDING_PATH}} | posture: {{POSTURE}}
# Scope guard: deploys ONLY use-case resources into {{TARGET_RESOURCE_GROUP}};
# never the central Citadel hub. See docs/threadlight-cicd/central-platform-boundary.md.

trigger:
  branches:
    include: [ main ]

pool:
  {{ADO_POOL_SPEC}}

variables:
  - name: AZURE_ENV_NAME
    value: {{ENV_NAME}}
  - name: AZURE_LOCATION
    value: {{TARGET_LOCATION}}
  - name: AZURE_SUBSCRIPTION_ID
    value: {{TARGET_SUBSCRIPTION_ID}}

stages:
  - stage: deploy
    displayName: Deploy ({{ENV_NAME}})
    jobs:
      - deployment: azd_deploy
        # Bind an ADO Environment to enable approval checks for production.
        environment: {{ENV_NAME}}
        strategy:
          runOnce:
            deploy:
              steps:
                - checkout: self
                - task: AzureCLI@2
                  displayName: Install azd
                  inputs:
                    azureSubscription: {{ADO_SERVICE_CONNECTION}}
                    scriptType: bash
                    scriptLocation: inlineScript
                    inlineScript: |
                      set -euo pipefail
                      curl -fsSL https://aka.ms/install-azd.sh | bash
                - task: AzureCLI@2
                  displayName: Provision infrastructure (azd)
                  inputs:
                    azureSubscription: {{ADO_SERVICE_CONNECTION}}
                    scriptType: bash
                    scriptLocation: inlineScript
                    inlineScript: |
                      set -euo pipefail
                      # AzureCLI@2 already established a federated az session via
                      # the WIF service connection; let azd reuse it.
                      azd config set auth.useAzCliAuth "true"
                      azd env new "$AZURE_ENV_NAME" \
                        --subscription "$AZURE_SUBSCRIPTION_ID" \
                        --location "$AZURE_LOCATION" \
                        --no-prompt || true
                      azd provision --no-prompt
                - task: AzureCLI@2
                  displayName: Deploy services (azd)
                  inputs:
                    azureSubscription: {{ADO_SERVICE_CONNECTION}}
                    scriptType: bash
                    scriptLocation: inlineScript
                    inlineScript: |
                      set -euo pipefail
                      azd config set auth.useAzCliAuth "true"
                      azd deploy --no-prompt

  # CAF "build agents across your organization": standardized evaluation +
  # dedicated AI red teaming, integrated into CI/CD. Both gate stages run the
  # threadlight Discover legs against the freshly deployed agent and enforce
  # their verdict. Gate mode: {{EVAL_GATE_MODE}} (soft = warn-only,
  # hard = block the pipeline on a non-pass verdict).
  - stage: eval_gate
    displayName: Eval gate ({{EVAL_GATE_MODE}})
    dependsOn: deploy
    jobs:
      - job: quality_evals
        steps:
          - checkout: self
          - task: AzureCLI@2
            displayName: Run quality evals (threadlight-evals Discover leg)
            inputs:
              azureSubscription: {{ADO_SERVICE_CONNECTION}}
              scriptType: bash
              scriptLocation: inlineScript
              inlineScript: |
                set -euo pipefail
                echo "Run threadlight-evals against $(AZURE_ENV_NAME) to (re)produce \
                  specs/evals-manifest.json — offline batch (foundry-evals), \
                  online/continuous eval on live threads, and the A/B \
                  champion-challenger gate."
          - task: AzureCLI@2
            displayName: Enforce eval verdict (mode={{EVAL_GATE_MODE}})
            continueOnError: {{EVAL_GATE_SOFT}}
            inputs:
              azureSubscription: {{ADO_SERVICE_CONNECTION}}
              scriptType: bash
              scriptLocation: inlineScript
              inlineScript: |
                set -euo pipefail
                python3 - <<'PY'
                import json, os, sys
                p = "specs/evals-manifest.json"
                if not os.path.exists(p):
                    print(f"##vso[task.logissue type=warning]{p} missing — evals leg has not run.")
                    sys.exit(1)
                verdict = json.load(open(p)).get("verdict", "not-verified")
                print(f"evals verdict: {verdict}")
                sys.exit(0 if verdict in ("pass", "passed", "ok") else 1)
                PY

  - stage: red_team_gate
    displayName: Red-team gate ({{EVAL_GATE_MODE}})
    dependsOn: deploy
    jobs:
      - job: adversarial_scan
        steps:
          - checkout: self
          - task: AzureCLI@2
            displayName: Run adversarial scan (threadlight-redteam Discover leg)
            inputs:
              azureSubscription: {{ADO_SERVICE_CONNECTION}}
              scriptType: bash
              scriptLocation: inlineScript
              inlineScript: |
                set -euo pipefail
                echo "Run threadlight-redteam against $(AZURE_ENV_NAME) to produce \
                  docs/redteam-report.md + specs/redteam-manifest.json — AI Red \
                  Teaming Agent scan for jailbreak / prompt-injection / \
                  exfiltration / harmful-content."
          - task: AzureCLI@2
            displayName: Enforce red-team verdict (mode={{EVAL_GATE_MODE}})
            continueOnError: {{EVAL_GATE_SOFT}}
            inputs:
              azureSubscription: {{ADO_SERVICE_CONNECTION}}
              scriptType: bash
              scriptLocation: inlineScript
              inlineScript: |
                set -euo pipefail
                python3 - <<'PY'
                import json, os, sys
                p = "specs/redteam-manifest.json"
                if not os.path.exists(p):
                    print(f"##vso[task.logissue type=warning]{p} missing — red-team scan has not run.")
                    sys.exit(1)
                verdict = json.load(open(p)).get("verdict", "not-verified")
                print(f"red-team verdict: {verdict}")
                sys.exit(0 if verdict in ("pass", "passed", "ok") else 1)
                PY

  # MCP supply-chain gate — see the GitHub template for rationale.
  # Gate mode: {{MCP_GATE_MODE}} (soft = warn-only, hard = block on must-fix).
  - stage: mcp_supply_chain_gate
    displayName: MCP supply-chain gate ({{MCP_GATE_MODE}})
    dependsOn: deploy
    jobs:
      - job: mcp_supply_chain
        steps:
          - checkout: self
          - task: AzureCLI@2
            displayName: Produce MCP SBOM (threadlight-production-ready)
            inputs:
              azureSubscription: {{ADO_SERVICE_CONNECTION}}
              scriptType: bash
              scriptLocation: inlineScript
              inlineScript: |
                set -euo pipefail
                echo "Run threadlight-production-ready against the repo to \
                  (re)produce tests/mcp-sbom.json — MCP server/tool discovery, \
                  pin + registry verification, mcp-lock.json drift, and \
                  inline-credential scan."
          - task: AzureCLI@2
            displayName: Enforce MCP supply-chain verdict (mode={{MCP_GATE_MODE}})
            continueOnError: {{MCP_GATE_SOFT}}
            inputs:
              azureSubscription: {{ADO_SERVICE_CONNECTION}}
              scriptType: bash
              scriptLocation: inlineScript
              inlineScript: |
                set -euo pipefail
                python3 - <<'PY'
                import json, os, sys
                p = "tests/mcp-sbom.json"
                if not os.path.exists(p):
                    print(f"##vso[task.logissue type=warning]{p} missing — MCP SBOM has not been produced.")
                    sys.exit(1)
                summary = json.load(open(p)).get("summary", {})
                must_fix = summary.get("must_fix", 0)
                print(f"MCP must-fix findings: {must_fix}")
                sys.exit(1 if must_fix else 0)
                PY
